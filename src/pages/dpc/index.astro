---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no" />
<title>⌖ DOTH PUNK COMMAND</title>
<meta name="description" content="Transmissions on God, Bitcoin, cryptocurrency, and code." />
<link rel="manifest" href="/dpc/manifest.webmanifest" />
<meta name="theme-color" content="#01030a" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="DPC" />
<link rel="icon" type="image/png" href="/dpc/icon-192.png" />
<link rel="apple-touch-icon" href="/dpc/icon-192.png" />
<style is:global>
  :root {
    --glow:  #00d2ff;
    --glow2: #7a5bff;
    --accent:#6dffa0;
    --core1: #ffffff;
    --core2: #8df6ff;
    --core3: #0a6cff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    height: 100%;
    background: #01030a;
    overflow: hidden;
    font-family: "Courier New", ui-monospace, monospace;
    color: #fff;
    -webkit-tap-highlight-color: transparent;
  }
  body::before {
    content: ""; position: fixed; inset: -60%;
    background:
      radial-gradient(circle at 18% 28%, color-mix(in srgb, var(--glow2) 35%, transparent), transparent 38%),
      radial-gradient(circle at 82% 72%, color-mix(in srgb, var(--glow) 32%, transparent), transparent 42%),
      radial-gradient(circle at 50% 50%, rgba(255,0,150,0.08), transparent 60%),
      #01030a;
    animation: drift 60s linear infinite; z-index: 0; transition: background 1.2s ease;
  }
  @keyframes drift { 0% { transform: rotate(0) scale(1.18); } 100% { transform: rotate(360deg) scale(1.18); } }

  #space { position: fixed; inset: 0; z-index: 1; pointer-events: none; }

  .stage { position: relative; z-index: 2; height: 100%; display: flex; align-items: center; justify-content: center; }

  /* ===== brand + controls ===== */
  .appbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 20;
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; padding-top: max(14px, env(safe-area-inset-top));
    pointer-events: none;
  }
  .brand {
    font-size: 13px; letter-spacing: 4px; color: #cfefff; text-transform: uppercase;
    text-shadow: 0 0 10px var(--glow); pointer-events: auto;
    display: flex; align-items: center; gap: 8px; user-select: none;
  }
  .brand .sig { color: var(--glow); font-size: 16px; }
  .appbar .spacer { flex: 1; }
  .btn {
    pointer-events: auto; cursor: pointer;
    font: inherit; font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: #cfefff; background: rgba(0,40,60,0.35); border: 1px solid color-mix(in srgb, var(--glow) 55%, transparent);
    border-radius: 8px; padding: 8px 12px; backdrop-filter: blur(4px);
    transition: background .2s, box-shadow .2s;
  }
  .btn:hover { background: rgba(0,80,110,0.5); box-shadow: 0 0 14px color-mix(in srgb, var(--glow) 50%, transparent); }
  #installBtn[hidden] { display: none; }

  /* channel menu */
  .menu {
    position: fixed; inset: 0; z-index: 30; display: none;
    align-items: center; justify-content: center;
    background: rgba(1,3,10,0.78); backdrop-filter: blur(6px);
  }
  .menu.show { display: flex; }
  .menu-inner {
    width: min(560px, 92vw); max-height: 86vh; overflow: auto;
    border: 1px solid color-mix(in srgb, var(--glow) 50%, transparent);
    border-radius: 16px; padding: 22px;
    background: linear-gradient(rgba(3,8,20,0.92), rgba(3,8,20,0.92));
    box-shadow: 0 0 60px color-mix(in srgb, var(--glow) 30%, transparent);
  }
  .menu h2 { font-size: 14px; letter-spacing: 5px; color: var(--glow); margin-bottom: 4px; }
  .menu p.sub { font-size: 11px; letter-spacing: 1px; color: #7fbfd6; margin-bottom: 16px; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .chip {
    cursor: pointer; font: inherit; font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    padding: 6px 12px; border-radius: 999px; color: #cfefff;
    border: 1px solid rgba(120,180,210,0.35); background: transparent; transition: .15s;
  }
  .chip.active { background: var(--glow); color: #02121a; border-color: var(--glow); font-weight: bold; box-shadow: 0 0 14px color-mix(in srgb, var(--glow) 60%, transparent); }
  .chan { display: flex; flex-direction: column; gap: 8px; }
  .chan button {
    text-align: left; cursor: pointer; font: inherit;
    display: flex; align-items: center; gap: 12px;
    padding: 12px 14px; border-radius: 10px; color: #eaf7ff;
    border: 1px solid rgba(120,180,210,0.25); background: rgba(0,30,50,0.3); transition: .15s;
  }
  .chan button:hover { background: rgba(0,60,90,0.45); border-color: color-mix(in srgb, var(--glow) 55%, transparent); transform: translateX(3px); }
  .chan .tdot { width: 10px; height: 10px; border-radius: 50%; flex: 0 0 auto; box-shadow: 0 0 8px currentColor; }
  .chan .ct { font-size: 13px; letter-spacing: 2px; }
  .chan .cs { font-size: 10px; letter-spacing: 1px; opacity: .6; margin-left: auto; text-transform: uppercase; }
  .menu .close { margin-top: 18px; width: 100%; text-align: center; }

  /* ===== THE TERMINAL ===== */
  .terminal {
    position: relative; width: min(940px, 94vw); height: 0vh; max-height: 84vh;
    border-radius: 16px; overflow: hidden;
    background:
      linear-gradient(rgba(2,6,16,0.90), rgba(2,6,16,0.90)),
      repeating-linear-gradient(115deg, rgba(0,200,255,0.04) 0 2px, transparent 2px 7px);
    backdrop-filter: blur(2px); opacity: 0;
    transform: scaleY(0.02) perspective(1200px) rotateX(8deg); transform-origin: center;
    transition: height 1.8s cubic-bezier(.16,.84,.3,1), opacity 1.3s ease, transform 1.8s cubic-bezier(.16,.84,.3,1);
    box-shadow: 0 0 80px color-mix(in srgb, var(--glow2) 38%, transparent), 0 0 160px color-mix(in srgb, var(--glow) 24%, transparent), inset 0 0 80px rgba(0,0,0,0.85);
  }
  .terminal::before {
    content: ""; position: absolute; inset: -3px; border-radius: 18px; padding: 3px;
    background: linear-gradient(130deg,#ff0040,#ff8a00,#ffe600,#36ff5e,#00e0ff,#4d5bff,#b400ff,#ff00c8,#ff0040);
    background-size: 400% 400%; animation: rainbow 6s linear infinite;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    z-index: 8; pointer-events: none; filter: drop-shadow(0 0 10px rgba(255,255,255,0.5));
  }
  @keyframes rainbow { 0% { background-position: 0% 50%; } 100% { background-position: 400% 50%; } }
  .terminal.open    { height: 84vh; opacity: 1; transform: scaleY(1) perspective(1200px) rotateX(0); }
  .terminal.closing { height: 0vh;  opacity: 0; transform: scaleY(0.02) perspective(1200px) rotateX(8deg); }

  .terminal .sweep { position: absolute; left:0; right:0; height: 40%; top: -42%;
    background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--glow) 14%, transparent), transparent);
    animation: sweep 4.5s linear infinite; pointer-events: none; z-index: 6; }
  @keyframes sweep { 0% { top: -42%; } 100% { top: 100%; } }

  #rain { position: absolute; inset: 0; z-index: 1; opacity: 0.16; pointer-events: none; }

  .glitchOverlay { position: absolute; inset: 0; z-index: 7; pointer-events: none; mix-blend-mode: screen; opacity: 0;
    background: linear-gradient(90deg, rgba(255,0,80,0.5), transparent 6%), linear-gradient(270deg, rgba(0,230,255,0.5), transparent 6%); }
  .glitchOverlay.fire { animation: rgbFire 0.42s steps(3) 1; }
  @keyframes rgbFire { 0%{opacity:0;transform:translateX(0)} 20%{opacity:.9;transform:translateX(-6px)} 50%{opacity:.4;transform:translateX(5px)} 80%{opacity:.7;transform:translateX(-3px)} 100%{opacity:0;transform:translateX(0)} }

  .corner { position: absolute; width: 30px; height: 30px; border: 2px solid var(--glow); z-index: 6; opacity: 0.85; filter: drop-shadow(0 0 6px var(--glow)); }
  .corner.tl { top:12px; left:12px; border-right:none; border-bottom:none; }
  .corner.tr { top:12px; right:12px; border-left:none; border-bottom:none; }
  .corner.bl { bottom:12px; left:12px; border-right:none; border-top:none; }
  .corner.br { bottom:12px; right:12px; border-left:none; border-top:none; }

  .grain { position: absolute; inset: 0; z-index: 5; opacity: 0.5; mix-blend-mode: overlay; pointer-events: none;
    background: repeating-linear-gradient(to bottom, rgba(255,255,255,0.035) 0px, rgba(255,255,255,0.035) 1px, transparent 1px, transparent 3px); }

  .inner { position: relative; z-index: 3; height: 100%; display: flex; flex-direction: column; padding: 22px 34px 30px; opacity: 0; transition: opacity 0.6s ease 0.7s; }
  .terminal.open .inner { opacity: 1; }

  .bar { display: flex; align-items: center; gap: 9px; padding-bottom: 10px; border-bottom: 1px solid color-mix(in srgb, var(--glow) 25%, transparent); flex: 0 0 auto; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot.r { background:#ff5f56; box-shadow:0 0 7px #ff5f56; } .dot.y { background:#ffbd2e; box-shadow:0 0 7px #ffbd2e; } .dot.g { background:#27c93f; box-shadow:0 0 7px #27c93f; }
  .bar .id { font-size: 11px; letter-spacing: 2px; color: #9fe9ff; opacity: 0.7; margin-left: 6px; }
  .bar .label { margin-left: auto; font-size: 11px; letter-spacing: 3px; color: #9fe9ff; text-transform: uppercase; opacity: 0.9; }
  .bar .label b { color: var(--accent); animation: liveblink 1.6s steps(1) infinite; }
  @keyframes liveblink { 50% { opacity: 0.2; } }

  .stack { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 14px; padding: 12px 0 6px; flex: 0 0 auto; }
  .readout { font-size: 10px; letter-spacing: 1px; color: color-mix(in srgb, var(--glow) 80%, #fff); opacity: 0.85; line-height: 1.9; text-transform: uppercase; }
  .readout.right { text-align: right; }
  .readout .v { color: #fff; }
  .readout .barline { display: inline-block; width: 60px; height: 5px; margin-left: 4px; background: color-mix(in srgb, var(--glow) 15%, transparent); border: 1px solid color-mix(in srgb, var(--glow) 40%, transparent); vertical-align: middle; overflow: hidden; }
  .readout .barline i { display: block; height: 100%; background: linear-gradient(90deg, var(--glow), var(--glow2)); box-shadow: 0 0 8px var(--glow); }

  .face { width: 210px; height: 210px; position: relative; margin: 0 auto; animation: float 6.5s ease-in-out infinite; filter: drop-shadow(0 0 16px color-mix(in srgb, var(--glow) 60%, transparent)); }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  .face svg { width: 100%; height: 100%; overflow: visible; }
  .ringSpin{transform-origin:100px 100px;animation:spin 18s linear infinite}
  .ringSpinR{transform-origin:100px 100px;animation:spin 12s linear infinite reverse}
  .ringSpin3{transform-origin:100px 100px;animation:spin 26s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}
  .pulseSlow{animation:pulseO 3.4s ease-in-out infinite}
  @keyframes pulseO{0%,100%{opacity:.3}50%{opacity:1}}
  .core{transform-origin:100px 76px;animation:corePulse 2.2s ease-in-out infinite}
  @keyframes corePulse{0%,100%{transform:scale(1);filter:drop-shadow(0 0 5px var(--core2))}50%{transform:scale(1.2);filter:drop-shadow(0 0 20px #fff)}}
  .eyeScan{animation:eyescan 4.5s ease-in-out infinite}
  @keyframes eyescan{0%,44%,100%{opacity:1}48%{opacity:.1}52%{opacity:1}}
  .faceScan{animation:faceScanMove 3.4s linear infinite}
  @keyframes faceScanMove{0%{transform:translateY(-50px);opacity:0}12%{opacity:.95}88%{opacity:.95}100%{transform:translateY(52px);opacity:0}}
  .breathe{animation:breathe 4s ease-in-out infinite;transform-origin:100px 100px}
  @keyframes breathe{0%,100%{opacity:.55}50%{opacity:1}}
  .flicker{animation:flick 6s steps(1) infinite}
  @keyframes flick{0%,96%,100%{opacity:1}97%{opacity:.5}98%{opacity:.85}99%{opacity:.6}}
  .mbar{transform-box:fill-box;transform-origin:center bottom;transition:transform .08s ease}
  .face.speaking .mbar{animation:talk .34s ease-in-out infinite}
  .face.speaking .mbar:nth-child(1){animation-delay:0s}.face.speaking .mbar:nth-child(2){animation-delay:.06s}
  .face.speaking .mbar:nth-child(3){animation-delay:.12s}.face.speaking .mbar:nth-child(4){animation-delay:.18s}.face.speaking .mbar:nth-child(5){animation-delay:.24s}
  @keyframes talk{0%,100%{transform:scaleY(.4)}50%{transform:scaleY(1.6)}}
  .orbit{transform-origin:100px 100px}
  .orbitA{animation:spin 5s linear infinite}.orbitB{animation:spin 7s linear infinite reverse}.orbitC{animation:spin 9s linear infinite}

  .boot { flex: 0 0 auto; padding: 6px 0 4px; font-size: 11px; letter-spacing: 1px; color: var(--accent); min-height: 18px; text-shadow: 0 0 6px color-mix(in srgb, var(--accent) 60%, transparent); }
  .progress { height: 6px; background: color-mix(in srgb, var(--glow) 12%, transparent); border: 1px solid color-mix(in srgb, var(--glow) 40%, transparent); border-radius: 3px; overflow: hidden; margin: 6px 0 4px; flex: 0 0 auto; }
  .progress i { display: block; height: 100%; width: 0%; background: linear-gradient(90deg, var(--glow), var(--glow2), #ff00c8); box-shadow: 0 0 10px var(--glow); transition: width 0.2s linear; }
  #wave { width: 100%; height: 30px; display: block; opacity: 0.9; flex: 0 0 auto; }

  .screen { flex: 1 1 auto; overflow: hidden; font-size: clamp(14px, 1.85vw, 20px); line-height: 1.7; color: #fff;
    text-shadow: 0 0 4px rgba(255,255,255,0.7), 0 0 10px color-mix(in srgb, var(--glow) 50%, transparent);
    white-space: pre-wrap; padding-top: 8px; margin-top: 4px; border-top: 1px solid color-mix(in srgb, var(--glow) 20%, transparent); }
  .line { display: block; } .prompt { color: var(--glow); opacity: 0.9; }
  .glitch { position: relative; display: inline; animation: jitter 2.6s steps(40) infinite; }
  @keyframes jitter { 0%,96%,100%{text-shadow:0 0 4px rgba(255,255,255,.7),0 0 10px rgba(120,200,255,.5);transform:translate(0,0)} 97%{text-shadow:-2px 0 #ff00c8,2px 0 #00e0ff;transform:translate(1px,-1px)} 98%{text-shadow:2px 0 #ff0040,-2px 0 #36ff5e;transform:translate(-1px,1px)} 99%{text-shadow:-1px 0 #b400ff,1px 0 #ffe600;transform:translate(1px,0)} }
  .scramble { color: var(--accent); opacity: 0.85; }
  .cursor { display: inline-block; width: 0.6ch; background: #fff; box-shadow: 0 0 8px #fff; animation: caret 1s steps(1) infinite; color: transparent; }
  @keyframes caret { 50% { opacity: 0; } }
  .stage::after { content: ""; position: fixed; inset: 0; pointer-events: none; background: radial-gradient(circle at center, transparent 50%, rgba(0,0,0,0.74) 100%); z-index: 5; }
</style>
</head>
<body>
  <canvas id="space"></canvas>

  <div class="appbar">
    <div class="brand"><span class="sig">⌖</span> DOTH PUNK COMMAND</div>
    <div class="spacer"></div>
    <button class="btn" id="installBtn" hidden>⤓ Install</button>
    <button class="btn" id="menuBtn">☰ Channels</button>
  </div>

  <div class="stage">
    <div class="terminal" id="term">
      <canvas id="rain"></canvas>
      <div class="sweep"></div>
      <div class="grain"></div>
      <div class="glitchOverlay" id="glitchOverlay"></div>
      <span class="corner tl"></span><span class="corner tr"></span><span class="corner bl"></span><span class="corner br"></span>

      <div class="inner">
        <div class="bar">
          <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
          <span class="id" id="hostId">root@theword</span>
          <span class="label" id="chanLabel">A.I. CORE &nbsp;·&nbsp; <b>● ONLINE</b></span>
        </div>

        <div class="stack">
          <div class="readout">
            <div>NEURAL <span class="v" id="ro1">000</span>%</div>
            <div>FLUX <span class="barline"><i id="bar1" style="width:50%"></i></span></div>
            <div>UPLINK <span class="v">ÆON</span></div>
            <div>TEMP <span class="v" id="ro2">00</span>K</div>
          </div>

          <div class="face" id="face">
            <svg viewBox="0 0 200 200" aria-hidden="true">
              <defs>
                <radialGradient id="coreG" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" style="stop-color:var(--core1)"/>
                  <stop offset="40%" style="stop-color:var(--core2)"/>
                  <stop offset="100%" style="stop-color:var(--core3)"/>
                </radialGradient>
                <linearGradient id="wire" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" style="stop-color:var(--glow)"/>
                  <stop offset="100%" style="stop-color:var(--glow2)"/>
                </linearGradient>
                <linearGradient id="visor" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" style="stop-color:var(--glow)" stop-opacity="0.55"/>
                  <stop offset="100%" style="stop-color:var(--glow2)" stop-opacity="0.12"/>
                </linearGradient>
                <clipPath id="faceClip"><path d="M100 34 C142 34 158 62 158 96 C158 134 134 170 100 178 C66 170 42 134 42 96 C42 62 58 34 100 34 Z"/></clipPath>
                <filter id="soft"><feGaussianBlur stdDeviation="0.6"/></filter>
              </defs>
              <g class="ringSpin3 pulseSlow"><circle cx="100" cy="100" r="96" fill="none" stroke="url(#wire)" stroke-width="0.8" stroke-dasharray="2 8"/></g>
              <g class="ringSpin pulseSlow">
                <circle cx="100" cy="100" r="90" fill="none" stroke="url(#wire)" stroke-width="1" stroke-dasharray="4 10"/>
                <circle cx="100" cy="100" r="83" fill="none" stroke="var(--glow)" stroke-width="0.5" opacity="0.5"/>
                <g fill="var(--core2)"><circle cx="100" cy="10" r="2"/><circle cx="190" cy="100" r="2"/><circle cx="100" cy="190" r="2"/><circle cx="10" cy="100" r="2"/></g>
              </g>
              <g class="ringSpinR">
                <circle cx="100" cy="100" r="77" fill="none" stroke="var(--glow2)" stroke-width="1" stroke-dasharray="22 14" opacity="0.7"/>
                <g stroke="var(--glow)" stroke-width="1.4" opacity="0.85">
                  <line x1="100" y1="14" x2="100" y2="22"/><line x1="100" y1="178" x2="100" y2="186"/><line x1="14" y1="100" x2="22" y2="100"/><line x1="178" y1="100" x2="186" y2="100"/>
                  <line x1="38" y1="38" x2="44" y2="44"/><line x1="156" y1="156" x2="162" y2="162"/><line x1="162" y1="38" x2="156" y2="44"/><line x1="44" y1="156" x2="38" y2="162"/>
                </g>
              </g>
              <g class="orbit orbitA"><circle cx="100" cy="14" r="2.4" fill="#fff"/><circle cx="100" cy="14" r="5" fill="none" stroke="var(--glow)" stroke-width="0.4" opacity="0.5"/></g>
              <g class="orbit orbitB"><circle cx="186" cy="100" r="2.2" fill="#ff8af0"/></g>
              <g class="orbit orbitC"><circle cx="100" cy="186" r="2.2" fill="var(--core2)"/></g>
              <g class="flicker">
                <path d="M100 34 C142 34 158 62 158 96 C158 134 134 170 100 178 C66 170 42 134 42 96 C42 62 58 34 100 34 Z" fill="rgba(4,20,40,0.6)" stroke="url(#wire)" stroke-width="2"/>
                <path d="M100 34 C142 34 158 62 158 96 C158 134 134 170 100 178 C66 170 42 134 42 96 C42 62 58 34 100 34 Z" fill="none" stroke="var(--glow)" stroke-width="0.5" opacity="0.4" transform="scale(0.92)" transform-origin="100 100"/>
                <g clip-path="url(#faceClip)"><rect x="42" y="84" width="116" height="26" fill="url(#visor)" class="breathe"/></g>
                <g stroke="var(--glow)" stroke-width="0.9" fill="none" opacity="0.85" filter="url(#soft)">
                  <path d="M100 42 L100 172"/><path d="M56 82 L100 76 L144 82"/><path d="M50 100 L78 110 L100 104 L122 110 L150 100"/>
                  <path d="M62 132 L100 124 L138 132"/><path d="M70 152 L100 162 L130 152"/><path d="M56 82 L50 100 L62 132 L70 152"/><path d="M144 82 L150 100 L138 132 L130 152"/>
                  <path d="M78 58 L100 54 L122 58 L144 82 M78 58 L56 82 M78 58 L100 76 M122 58 L100 76"/>
                  <path d="M60 112 L68 112 L72 118 M140 112 L132 112 L128 118" stroke="var(--glow2)"/>
                  <path d="M64 140 L74 140 L78 134 M136 140 L126 140 L122 134" stroke="var(--glow2)"/>
                </g>
                <g fill="var(--core2)">
                  <circle cx="100" cy="54" r="1.8"/><circle cx="56" cy="82" r="1.8"/><circle cx="144" cy="82" r="1.8"/><circle cx="50" cy="100" r="1.8"/><circle cx="150" cy="100" r="1.8"/><circle cx="100" cy="162" r="1.8"/><circle cx="68" cy="112" r="1.3"/><circle cx="132" cy="112" r="1.3"/>
                </g>
                <g class="eyeScan">
                  <rect x="66" y="92" width="24" height="7" rx="3.5" fill="url(#coreG)"/><rect x="110" y="92" width="24" height="7" rx="3.5" fill="url(#coreG)"/>
                  <circle cx="78" cy="95.5" r="7" fill="var(--core2)" opacity="0.45"/><circle cx="122" cy="95.5" r="7" fill="var(--core2)" opacity="0.45"/>
                </g>
                <g class="core">
                  <circle cx="100" cy="76" r="8" fill="url(#coreG)"/><circle cx="100" cy="76" r="11" fill="none" stroke="#fff" stroke-width="0.8" opacity="0.7"/>
                  <g stroke="#fff" stroke-width="0.6" opacity="0.7"><line x1="100" y1="65" x2="100" y2="69"/><line x1="100" y1="83" x2="100" y2="87"/><line x1="89" y1="76" x2="93" y2="76"/><line x1="107" y1="76" x2="111" y2="76"/></g>
                </g>
                <g fill="var(--glow)" id="mouth">
                  <rect class="mbar" x="84" y="132" width="3.2" height="12" rx="1.5"/><rect class="mbar" x="90" y="128" width="3.2" height="20" rx="1.5"/><rect class="mbar" x="96" y="124" width="3.2" height="28" rx="1.5"/><rect class="mbar" x="102" y="128" width="3.2" height="20" rx="1.5"/><rect class="mbar" x="108" y="132" width="3.2" height="12" rx="1.5"/>
                </g>
              </g>
              <g clip-path="url(#faceClip)"><rect class="faceScan" x="40" y="100" width="120" height="3" fill="var(--core2)" opacity="0.9"/></g>
            </svg>
          </div>

          <div class="readout right">
            <div><span class="v" id="ro3">00</span>% SOUL</div>
            <div><span class="barline"><i id="bar2" style="width:70%"></i></span> SYNC</div>
            <div>FAITH <span class="v">∞</span></div>
            <div>SIGNAL <span class="v" id="ro4">000</span>Hz</div>
          </div>
        </div>

        <div class="boot" id="boot"></div>
        <div class="progress"><i id="prog"></i></div>
        <canvas id="wave"></canvas>
        <div class="screen" id="screen"></div>
      </div>
    </div>
  </div>

  <!-- channel menu -->
  <div class="menu" id="menu">
    <div class="menu-inner">
      <h2>⌖ DOTH PUNK COMMAND</h2>
      <p class="sub">Select a transmission. Filter by frequency.</p>
      <div class="chips" id="chips"></div>
      <div class="chan" id="chanList"></div>
      <button class="btn close" id="closeMenu">CLOSE</button>
    </div>
  </div>

<script>
  import { transmissions, palettes } from "../../data/transmissions.js";

  const $ = (id) => document.getElementById(id);
  const term = $("term"), screen = $("screen"), face = $("face"),
        bootEl = $("boot"), prog = $("prog"), overlay = $("glitchOverlay"),
        hostId = $("hostId"), chanLabel = $("chanLabel");
  const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
  const rand = (a, b) => a + Math.random() * (b - a);

  const themeColor = { divine:"#00d2ff", bitcoin:"#ff9e2c", crypto:"#19ffa6", code:"#36ff8e" };

  // ---- engine state ----
  let order = transmissions.map((_, i) => i);   // playlist (indices into transmissions)
  let pos = 0;                                   // position in `order`
  let runToken = 0;                              // bumped to interrupt the running cycle
  let palette = palettes.divine;

  function applyPalette(themeKey) {
    palette = palettes[themeKey] || palettes.divine;
    const r = document.documentElement.style;
    r.setProperty("--glow", palette.glow);
    r.setProperty("--glow2", palette.glow2);
    r.setProperty("--accent", palette.accent);
    r.setProperty("--core1", palette.core1);
    r.setProperty("--core2", palette.core2);
    r.setProperty("--core3", palette.core3);
    $("term").style.colorScheme = "dark";
    document.querySelector('meta[name=theme-color]').setAttribute("content", "#01030a");
  }

  /* ---------- canvas: star universe ---------- */
  (function space() {
    const c = $("space"), x = c.getContext("2d"); let w, h, stars;
    function init() {
      w = c.width = innerWidth; h = c.height = innerHeight;
      stars = Array.from({ length: 220 }, () => ({ x: rand(-w/2, w/2), y: rand(-h/2, h/2), z: rand(0, w) }));
    }
    function frame() {
      x.fillStyle = "rgba(1,3,10,0.35)"; x.fillRect(0, 0, w, h);
      x.save(); x.translate(w/2, h/2);
      for (const s of stars) {
        s.z -= 1.2; if (s.z <= 0) { s.z = w; s.x = rand(-w/2, w/2); s.y = rand(-h/2, h/2); }
        const k = 128 / s.z, px = s.x*k, py = s.y*k, size = (1 - s.z/w) * 2.2;
        x.beginPath(); x.fillStyle = palette.core2; x.globalAlpha = Math.min(1, (1 - s.z/w) * 1.4);
        x.arc(px, py, Math.max(0.2, size), 0, 6.283); x.fill();
      }
      x.restore(); x.globalAlpha = 1; requestAnimationFrame(frame);
    }
    addEventListener("resize", init); init(); frame();
  })();

  /* ---------- canvas: matrix rain ---------- */
  (function rainFx() {
    const c = $("rain"), x = c.getContext("2d");
    const glyphs = "アカサタナ0123456789✝₿ΑΩ$#%&λΣΦΨ".split("");
    let cols, drops, w, h;
    function init() { w = c.width = term.clientWidth; h = c.height = term.clientHeight; cols = Math.floor(w/14); drops = Array.from({ length: cols }, () => rand(-50, 0)); }
    function frame() {
      x.fillStyle = "rgba(2,6,16,0.10)"; x.fillRect(0, 0, w, h); x.font = "13px monospace";
      for (let i = 0; i < cols; i++) {
        x.fillStyle = Math.random() > 0.97 ? "#eafcff" : palette.glow;
        x.globalAlpha = Math.random() > 0.97 ? 1 : 0.5;
        x.fillText(glyphs[Math.floor(rand(0, glyphs.length))], i*14, drops[i]*16);
        if (drops[i]*16 > h && Math.random() > 0.975) drops[i] = 0; drops[i]++;
      }
      x.globalAlpha = 1; requestAnimationFrame(frame);
    }
    new ResizeObserver(init).observe(term); init(); frame();
  })();

  /* ---------- canvas: reactive waveform ---------- */
  let speaking = false;
  (function wave() {
    const c = $("wave"), x = c.getContext("2d"); let w, h, t = 0;
    function init() { w = c.width = c.clientWidth; h = c.height = 30; }
    function frame() {
      if (!w) init(); x.clearRect(0, 0, w, h); x.beginPath();
      const amp = speaking ? 9 : 1.4;
      for (let i = 0; i <= w; i += 4) {
        const n = Math.sin(i*0.05 + t) * Math.sin(i*0.013 - t*0.7);
        const j = speaking ? (Math.random()-0.5)*6 : 0;
        const y = h/2 + n*amp + j; i === 0 ? x.moveTo(i, y) : x.lineTo(i, y);
      }
      x.strokeStyle = palette.glow; x.lineWidth = 1.6; x.shadowBlur = 8; x.shadowColor = palette.glow; x.stroke();
      t += 0.18; requestAnimationFrame(frame);
    }
    addEventListener("resize", init); init(); frame();
  })();

  /* ---------- live telemetry ---------- */
  (function telemetry() {
    const ro1=$("ro1"),ro2=$("ro2"),ro3=$("ro3"),ro4=$("ro4"),bar1=$("bar1"),bar2=$("bar2");
    (function tick() {
      ro1.textContent = String(Math.floor(rand(96,100))).padStart(3,"0");
      ro2.textContent = String(Math.floor(rand(3,9))).padStart(2,"0");
      ro3.textContent = String(Math.floor(rand(97,100))).padStart(2,"0");
      ro4.textContent = String(Math.floor(rand(420,820))).padStart(3,"0");
      bar1.style.width = rand(70,100)+"%"; bar2.style.width = rand(72,98)+"%";
      setTimeout(tick, 420);
    })();
  })();

  /* ---------- glitch bursts ---------- */
  (function glitchPulse() {
    (function go() { overlay.classList.remove("fire"); void overlay.offsetWidth; overlay.classList.add("fire"); setTimeout(go, rand(2600, 6000)); })();
  })();

  /* ---------- typing engine ---------- */
  const GLYPHS = "!<>-_\\/[]{}—=+*^?#01ΑΩλΣΦ✝₿";
  const TYPE_MS = 30, LINE_GAP = 240, OPEN_MS = 2100, READ_MS = 3400, CLOSE_MS = 2000, RESET_MS = 950;

  function newLine(p) {
    const line = document.createElement("span"); line.className = "line";
    if (p) { const ps = document.createElement("span"); ps.className = "prompt"; ps.textContent = p; line.appendChild(ps); }
    const g = document.createElement("span"); g.className = "glitch"; line.appendChild(g); screen.appendChild(line); return g;
  }
  function addCursor(el) { const c = document.createElement("span"); c.className = "cursor"; c.textContent = "█"; el.appendChild(c); return c; }

  async function typeChar(target, cursor, ch) {
    if (ch === " ") { target.insertBefore(document.createTextNode(" "), cursor); return; }
    const span = document.createElement("span"); span.className = "scramble"; target.insertBefore(span, cursor);
    for (let i = 0; i < 2; i++) { span.textContent = GLYPHS[Math.floor(rand(0, GLYPHS.length))]; await sleep(26); }
    span.className = ""; span.textContent = ch;
  }

  async function typeLine(token, prompt, text) {
    const target = newLine(prompt), cursor = addCursor(target);
    face.classList.add("speaking"); speaking = true;
    for (const ch of text) {
      if (token !== runToken) { cursor.remove(); return false; }
      await typeChar(target, cursor, ch); screen.scrollTop = screen.scrollHeight;
      await sleep(TYPE_MS + Math.floor(rand(0, 22)));
    }
    face.classList.remove("speaking"); speaking = false; cursor.remove(); return true;
  }

  async function runBoot(token, boot) {
    bootEl.textContent = ""; prog.style.width = "0%";
    for (let i = 0; i < boot.length; i++) {
      if (token !== runToken) return false;
      bootEl.textContent = boot[i]; prog.style.width = Math.round(((i+1)/boot.length)*100) + "%";
      await sleep(440);
    }
    await sleep(250); bootEl.textContent = ""; return token === runToken;
  }

  async function playTransmission(token, tx) {
    applyPalette(tx.theme);
    hostId.textContent = "root@" + tx.host;
    chanLabel.innerHTML = tx.title + " &nbsp;·&nbsp; <b>● LIVE</b>";

    screen.innerHTML = "";
    term.classList.remove("closing"); term.classList.add("open");
    await sleep(OPEN_MS); if (token !== runToken) return;

    if (!(await runBoot(token, tx.boot))) return;

    const lines = [
      { p: "root@" + tx.host + ":~$ ", t: tx.invoke },
      { p: "", t: "" },
      ...tx.lines.map((l) => ({ p: l ? "> " : "", t: l })),
      { p: "", t: "" },
      { p: "root@" + tx.host + ":~$ ", t: tx.sign },
    ];
    for (const ln of lines) {
      if (token !== runToken) return;
      if (ln.t === "") { newLine(""); await sleep(LINE_GAP); }
      else { if (!(await typeLine(token, ln.p, ln.t))) return; await sleep(LINE_GAP); }
    }

    await sleep(READ_MS); if (token !== runToken) return;
    term.classList.remove("open"); term.classList.add("closing");
    await sleep(CLOSE_MS + RESET_MS);
  }

  // main loop: walk the playlist forever
  async function runFrom(startPos) {
    const token = ++runToken;
    // ensure terminal closed before (re)starting cleanly
    term.classList.remove("open"); term.classList.add("closing");
    await sleep(120);
    pos = startPos;
    while (token === runToken) {
      const tx = transmissions[order[pos]];
      await playTransmission(token, tx);
      if (token !== runToken) return;
      pos = (pos + 1) % order.length;
    }
  }

  /* ---------- channel menu ---------- */
  const menu = $("menu"), chips = $("chips"), chanList = $("chanList");
  let filter = "all";

  function buildMenu() {
    // theme chips
    const themes = ["all", ...Object.keys(palettes)];
    chips.innerHTML = "";
    for (const t of themes) {
      const b = document.createElement("button");
      b.className = "chip" + (t === filter ? " active" : "");
      b.textContent = t === "all" ? "ALL" : palettes[t].label;
      b.onclick = () => { filter = t; rebuildOrder(); buildMenu(); };
      chips.appendChild(b);
    }
    // channel list (respecting filter)
    chanList.innerHTML = "";
    transmissions.forEach((tx, i) => {
      if (filter !== "all" && tx.theme !== filter) return;
      const b = document.createElement("button");
      const dot = document.createElement("span"); dot.className = "tdot";
      dot.style.color = themeColor[tx.theme] || "#fff";
      const t = document.createElement("span"); t.className = "ct"; t.textContent = tx.title;
      const s = document.createElement("span"); s.className = "cs"; s.textContent = palettes[tx.theme].label;
      b.append(dot, t, s);
      b.onclick = () => {
        rebuildOrder();
        const target = order.indexOf(i);
        menu.classList.remove("show");
        runFrom(target >= 0 ? target : 0);
      };
      chanList.appendChild(b);
    });
  }

  function rebuildOrder() {
    order = transmissions.map((_, i) => i).filter((i) => filter === "all" || transmissions[i].theme === filter);
    if (order.length === 0) order = transmissions.map((_, i) => i);
  }

  $("menuBtn").onclick = () => { buildMenu(); menu.classList.add("show"); };
  $("closeMenu").onclick = () => menu.classList.remove("show");
  menu.onclick = (e) => { if (e.target === menu) menu.classList.remove("show"); };

  /* ---------- PWA: install prompt + service worker ---------- */
  let deferredPrompt = null;
  const installBtn = $("installBtn");
  window.addEventListener("beforeinstallprompt", (e) => { e.preventDefault(); deferredPrompt = e; installBtn.hidden = false; });
  installBtn.onclick = async () => { if (!deferredPrompt) return; deferredPrompt.prompt(); await deferredPrompt.userChoice; deferredPrompt = null; installBtn.hidden = true; };
  window.addEventListener("appinstalled", () => { installBtn.hidden = true; });
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", () => navigator.serviceWorker.register("/dpc/sw.js", { scope: "/dpc/" }).catch(() => {}));
  }

  /* ---------- go ---------- */
  applyPalette(transmissions[0].theme);
  (async () => { await sleep(400); runFrom(0); })();
</script>
</body>
</html>
